@model CAS.DTOs.Crop.CreateCropRequestModel

@{
    ViewData["Title"] = "Add Crop";
    Layout = "_AdminLayout";
}

<section class="section">
    <div class="container-fluid">

        @if (ViewBag.ErrorMessage != null)
        {
            
            <div class="alert alert-danger" role="alert">
                @ViewBag.ErrorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>

            
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success" role="alert">
                  @TempData["SuccessMessage"]
                   @* <button type="button" class="btn-close" data-bs-dismiss="alert"></button> *@
               </div>
            
        }


        <!-- Page Header -->
        <div class="title-wrapper pt-30 mb-4">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h2 class="mb-1">🌱 Add New Crop</h2>
                    <p class="text-muted mb-0">
                        Create a crop that farmers can use throughout the system.
                    </p>
                </div>

                <div class="col-md-4 text-md-end mt-3 mt-md-0">
                    <a asp-action="ListOfCrops" class="main-btn light-btn btn-hover">
                        <i class="lni lni-arrow-left"></i>
                        Back to Crops
                    </a>
                </div>
            </div>
        </div>

        <form asp-action="AddCrop" method="post" enctype="multipart/form-data">

            <div class="row">

                <!-- LEFT -->
                <div class="col-lg-4">

                    <div class="card-style mb-30">

                        <h5 class="mb-3">
                            <i class="lni lni-image"></i>
                            Crop Image
                        </h5>

                        <div class="text-center">

                            <img id="preview"
                                 src="~/assets/images/no-image.png"
                                 class="img-fluid rounded shadow-sm mb-3"
                                 style="height:250px;width:100%;object-fit:cover;" />

                        </div>

                        <label class="upload-box">

                            <i class="lni lni-cloud-upload upload-icon"></i>

                            <h6 class="mt-3">Click to upload</h6>

                            <p class="text-muted mb-2">
                                PNG, JPG or WEBP
                            </p>

                            <input asp-for="Image"
                                   id="imageInput"
                                   type="file"
                                   accept="image/*"
                                   hidden />

                        </label>

                        <span asp-validation-for="Image" class="text-danger small"></span>

                    </div>

                </div>

                <!-- RIGHT -->
                <div class="col-lg-8">

                    <div class="card-style mb-30">

                        <h5 class="mb-4">
                            <i class="lni lni-pencil-alt"></i>
                            Crop Information
                        </h5>

                        <div class="mb-4">

                            <label asp-for="Name" class="form-label fw-bold">
                                Crop Name
                            </label>

                            <input asp-for="Name"
                                   class="form-control form-control-lg"
                                   placeholder="e.g Maize" />

                            <span asp-validation-for="Name"
                                  class="text-danger"></span>

                        </div>

                        <div class="mb-4">

                            <label asp-for="Description"
                                   class="form-label fw-bold">

                                Description

                            </label>

                            <textarea asp-for="Description"
                                      rows="8"
                                      class="form-control"
                                      placeholder="Write a short description about this crop..."></textarea>

                            <span asp-validation-for="Description"
                                  class="text-danger"></span>

                        </div>

                        <hr>

                        <div class="d-flex justify-content-end">

                            <a asp-action="ListOfCrops"
                               class="btn btn-outline-secondary me-2">

                                Cancel

                            </a>

                            <button class="main-btn primary-btn btn-hover px-4"
                                    type="submit">

                                <i class="lni lni-save"></i>

                                Save Crop

                            </button>

                        </div>

                    </div>

                </div>

            </div>

        </form>

    </div>
</section>

<style>

    .upload-box {
        border: 2px dashed #d8e2ef;
        border-radius: 12px;
        padding: 35px;
        cursor: pointer;
        display: block;
        text-align: center;
        transition: .3s;
        background: #fafbfd;
    }

        .upload-box:hover {
            border-color: #365cf5;
            background: #f4f7ff;
        }

    .upload-icon {
        font-size: 45px;
        color: #365cf5;
    }

    .form-control {
        border-radius: 10px;
    }

    .card-style {
        border-radius: 15px;
    }

</style>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>

        document.getElementById("imageInput").addEventListener("change", function(e){

            const file = e.target.files[0];

            if(!file) return;

            const reader = new FileReader();

            reader.onload = function(x){

                document.getElementById("preview").src = x.target.result;

            }

            reader.readAsDataURL(file);

        });

    </script>

}