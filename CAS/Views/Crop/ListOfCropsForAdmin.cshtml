@using CAS.DTOs
@using CAS.DTOs.Crop
@model BaseResponse<IReadOnlyList<CropListResponseModel>>

@{
    Layout = "_AdminLayout";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="shortcut icon" href="~/assets/images/favicon.svg" type="image/x-icon" />
    <title>Crops</title>

    <!-- ========== All CSS files linkup ========= -->
    <link rel="stylesheet" href="~/assets/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/assets/css/lineicons.css" />
    <link rel="stylesheet" href="~/assets/css/materialdesignicons.min.css" />
    <link rel="stylesheet" href="~/assets/css/fullcalendar.css" />
    <link rel="stylesheet" href="~/assets/css/main.css" />
</head>
<body>
    <div class="title d-flex justify-content-between align-items-center flex-wrap">
        <h2>Crop Management</h2>

        <a asp-action="AddCrop"
           asp-controller="Crop"
           class="main-btn primary-btn btn-hover">
            <i class="lni lni-plus"></i>
            Add New Crop
        </a>
    </div>

    <div class="card-style mb-30">

        <div class="table-wrapper table-responsive">

            <table class="table">

                <thead>
                    <tr>
                        <th width="90">Image</th>
                        <th>Name</th>
                        <th>Status</th>
                        <th width="180" class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model.Data != null && Model.Data.Any())
                    {
                        foreach (var crop in Model.Data)
                        {
                            <tr>

                                <td>

                                    @if (!string.IsNullOrEmpty(crop.ImageUrl))
                                    {
                                        <img src="@crop.ImageUrl"
                                             width="70"
                                             height="70"
                                             style="object-fit:cover;border-radius:8px;" />
                                    }
                                    else
                                    {
                                        <img src="~/images/no-image.png"
                                             width="70"
                                             height="70"
                                             style="object-fit:cover;border-radius:8px;" />
                                    }

                                </td>

                                <td class="align-middle">

                                    <h6 class="mb-0">@crop.Name</h6>

                                </td>

                                <td class="align-middle">

                                    @if (crop.CropStatus == CAS.Contracts.Enums.Status.Active)
                                    {
                                        <span class="badge bg-success">Active</span>
                                        <a asp-action="DeactivateCrop" asp-controller="Crop" asp-route-id="@crop.Id" class="main-btn light-btn btn-hover">
                                            Deactivate Crop
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                        <a asp-action="ActivateCrop" asp-controller="Crop" asp-route-id="@crop.Id" class="main-btn light-btn btn-hover">
                                            Activate Crop
                                        </a>
                                    }

                                </td>

                                <td class="text-center align-middle">

                                    <a asp-action="ViewCropDetails"
                                       asp-route-id="@crop.Id"
                                       class="btn btn-sm btn-info">

                                        <i class="lni lni-eye"></i>

                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@crop.Id"
                                       class="btn btn-sm btn-warning">

                                        <i class="lni lni-pencil"></i>

                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@crop.Id"
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('Delete this crop?')">

                                        <i class="lni lni-trash-can"></i>

                                    </a>

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="3">

                                <div class="text-center py-5">

                                    <img src="~/assets/images/empty.svg"
                                         width="180"
                                         class="mb-3" />

                                    <h5>No Crops Found</h5>

                                    <p class="text-muted">
                                        There are currently no crops in the database.
                                    </p>

                                    <a asp-action="AddCrop"
                                       class="main-btn primary-btn btn-hover">

                                        Add First Crop

                                    </a>

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>
    <!-- ======== main-wrapper end =========== -->
    <!-- ========= All Javascript files linkup ======== -->
    <script src="~/assets/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/js/Chart.min.js"></script>
    <script src="~/assets/js/dynamic-pie-chart.js"></script>
    <script src="~/assets/js/moment.min.js"></script>
    <script src="~/assets/js/fullcalendar.js"></script>
    <script src="~/assets/js/jvectormap.min.js"></script>
    <script src="~/assets/js/world-merc.js"></script>
    <script src="~/assets/js/polyfill.js"></script>
    <script src="~/assets/js/main.js"></script>
</body>
</html>
